{
  "name": "ecommerce-platform",
  "version": "1.0.0",
  "description": "Enterprise Angular eCommerce Platform with Microfrontend Architecture",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:b2c": "ng serve b2c-app --port 4200",
    "start:b2b": "ng serve b2b-app --port 4300",
    "start:admin": "ng serve admin-app --port 4400",
    "start:auth": "ng serve auth --port 4201",
    "start:product": "ng serve product --port 4202",
    "start:cart": "ng serve cart --port 4203",
    "start:checkout": "ng serve checkout --port 4204",
    "start:order": "ng serve order --port 4205",
    "start:payment": "ng serve payment --port 4206",
    "start:review": "ng serve review --port 4207",
    "start:promotion": "ng serve promotion --port 4208",
    "start:b2b-feature": "ng serve b2b --port 4209",
    "start:admin-feature": "ng serve admin --port 4210",
    "start:all": "concurrently \"npm:start:b2c\" \"npm:start:auth\" \"npm:start:product\" \"npm:start:cart\" \"npm:start:checkout\" \"npm:start:order\"",
    "build": "ng build",
    "build:b2c": "ng build b2c-app --configuration production",
    "build:b2b": "ng build b2b-app --configuration production",
    "build:admin": "ng build admin-app --configuration production",
    "build:all": "npm run build:b2c && npm run build:b2b && npm run build:admin",
    "watch": "ng build --watch --configuration development",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "format": "prettier --write \"**/*.{ts,html,scss,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,html,scss,json,md}\"",
    "e2e": "cypress open",
    "e2e:headless": "cypress run",
    "analyze": "webpack-bundle-analyzer dist/apps/b2c-app/stats.json",
    "clean": "rm -rf dist node_modules/.cache"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.0.0",
    "@angular/cdk": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/material": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-browser-dynamic": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@ngrx/signals": "^18.0.0",
    "rxjs": "^7.8.0",
    "tslib": "^2.6.0",
    "zone.js": "^0.14.0",
    "date-fns": "^3.0.0",
    "lodash-es": "^4.17.21"
  },
  "devDependencies": {
    "@angular-architects/module-federation": "^18.0.0",
    "@angular-devkit/build-angular": "^21.0.0",
    "@angular-eslint/builder": "^21.0.0",
    "@angular-eslint/eslint-plugin": "^21.0.0",
    "@angular-eslint/eslint-plugin-template": "^21.0.0",
    "@angular-eslint/schematics": "^21.0.0",
    "@angular-eslint/template-parser": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@types/jest": "^29.5.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "concurrently": "^8.2.0",
    "cypress": "^13.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "jest-preset-angular": "^14.0.0",
    "prettier": "^3.2.0",
    "typescript": "~5.4.0",
    "webpack-bundle-analyzer": "^4.10.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "angular",
    "ecommerce",
    "microfrontend",
    "module-federation",
    "b2c",
    "b2b",
    "enterprise"
  ],
  "author": "Your Company",
  "license": "MIT"
}